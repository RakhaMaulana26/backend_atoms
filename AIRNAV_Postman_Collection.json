{
  "info": {
    "name": "AIRNAV Backend API",
    "description": "API Collection untuk Sistem Rostering & Shift Management AIRNAV",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000/api",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@airnav.com\",\n  \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Verify Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"ABC-XYZ123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/verify-token",
              "host": ["{{base_url}}"],
              "path": ["auth", "verify-token"]
            }
          }
        },
        {
          "name": "Set Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"ABC-XYZ123\",\n  \"password\": \"Password123\",\n  \"password_confirmation\": \"Password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/set-password",
              "host": ["{{base_url}}"],
              "path": ["auth", "set-password"]
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["auth", "logout"]
            }
          }
        }
      ]
    },
    {
      "name": "Admin - User Management",
      "item": [
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/users?per_page=15&role=cns",
              "host": ["{{base_url}}"],
              "path": ["admin", "users"],
              "query": [
                {
                  "key": "per_page",
                  "value": "15"
                },
                {
                  "key": "role",
                  "value": "cns"
                }
              ]
            }
          }
        },
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Andi Pratama\",\n  \"email\": \"andi@airnav.com\",\n  \"role\": \"cns\",\n  \"employee_type\": \"CNS\",\n  \"is_active\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/admin/users",
              "host": ["{{base_url}}"],
              "path": ["admin", "users"]
            }
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Andi Pratama Updated\",\n  \"is_active\": false\n}"
            },
            "url": {
              "raw": "{{base_url}}/admin/users/2",
              "host": ["{{base_url}}"],
              "path": ["admin", "users", "2"]
            }
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/users/2",
              "host": ["{{base_url}}"],
              "path": ["admin", "users", "2"]
            }
          }
        },
        {
          "name": "Restore User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/users/2/restore",
              "host": ["{{base_url}}"],
              "path": ["admin", "users", "2", "restore"]
            }
          }
        },
        {
          "name": "Generate Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"activation\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/admin/users/2/generate-token",
              "host": ["{{base_url}}"],
              "path": ["admin", "users", "2", "generate-token"]
            }
          }
        }
      ]
    },
    {
      "name": "Rostering",
      "item": [
        {
          "name": "Create Roster",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"month\": 1,\n  \"year\": 2026,\n  \"days\": [\n    {\n      \"date\": \"2026-01-01\",\n      \"manager_id\": 1,\n      \"shifts\": {\n        \"pagi\": [2, 3, 4, 5, 6, 7],\n        \"siang\": [8, 9, 10, 11, 12, 13],\n        \"malam\": [14, 15, 16, 17, 18, 19]\n      }\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/rosters",
              "host": ["{{base_url}}"],
              "path": ["rosters"]
            }
          }
        },
        {
          "name": "Get Roster Detail",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/rosters/1",
              "host": ["{{base_url}}"],
              "path": ["rosters", "1"]
            }
          }
        },
        {
          "name": "Publish Roster",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/rosters/1/publish",
              "host": ["{{base_url}}"],
              "path": ["rosters", "1", "publish"]
            }
          }
        }
      ]
    },
    {
      "name": "Shift Request",
      "item": [
        {
          "name": "Create Shift Request",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"target_employee_id\": 3,\n  \"from_roster_day_id\": 1,\n  \"to_roster_day_id\": 2,\n  \"shift_id\": 1,\n  \"reason\": \"Keperluan keluarga\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/shift-requests",
              "host": ["{{base_url}}"],
              "path": ["shift-requests"]
            }
          }
        },
        {
          "name": "Approve by Target",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/shift-requests/1/approve-target",
              "host": ["{{base_url}}"],
              "path": ["shift-requests", "1", "approve-target"]
            }
          }
        },
        {
          "name": "Approve by Manager",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/shift-requests/1/approve-manager",
              "host": ["{{base_url}}"],
              "path": ["shift-requests", "1", "approve-manager"]
            }
          }
        },
        {
          "name": "Reject Request",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/shift-requests/1/reject",
              "host": ["{{base_url}}"],
              "path": ["shift-requests", "1", "reject"]
            }
          }
        }
      ]
    },
    {
      "name": "Notifications",
      "item": [
        {
          "name": "Get Notifications",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/notifications?is_read=false&per_page=20",
              "host": ["{{base_url}}"],
              "path": ["notifications"],
              "query": [
                {
                  "key": "is_read",
                  "value": "false"
                },
                {
                  "key": "per_page",
                  "value": "20"
                }
              ]
            }
          }
        },
        {
          "name": "Mark as Read",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/notifications/1/read",
              "host": ["{{base_url}}"],
              "path": ["notifications", "1", "read"]
            }
          }
        }
      ]
    }
  ]
}
